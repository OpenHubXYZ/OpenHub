{
  "name": "theopenhub-skills-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "electron", "esbuild"]
  },
  "scripts": {
    "dev": "pnpm --filter @theopenhub/desktop dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r --sort typecheck",
    "test": "vitest run",
    "build": "pnpm -r --sort build",
    "assets:icons": "node scripts/generate-icons.mjs",
    "package:desktop": "pnpm assets:icons && pnpm build && node scripts/package-desktop.mjs",
    "release:checksums": "node scripts/generate-checksums.mjs",
    "release:inventory": "node scripts/generate-dependency-inventory.mjs",
    "release:smoke": "node scripts/release-smoke.mjs"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^37.2.6",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  }
}
