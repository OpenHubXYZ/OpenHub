{
  "appId": "io.openhub.desktop",
  "productName": "OpenHub",
  "artifactName": "openhub",
  "unpackedDirectory": "out/packages",
  "releaseDirectory": "out/release",
  "targets": {
    "darwin": {
      "formats": ["dir", "dmg"],
      "signing": "required-for-public-release"
    },
    "win32": {
      "formats": ["dir", "nsis"],
      "signing": "required-for-public-release"
    },
    "linux": {
      "formats": ["dir", "AppImage", "deb"],
      "signing": "checksum-required"
    }
  }
}
